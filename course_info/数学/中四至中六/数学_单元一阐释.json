  "unit_overview": {
    "title": "数学延伸部分（单元一：微积分与统计）",
    "focus": "微积分与统计",
    "prerequisites": ["数学必修部分"],
    "target_students": ["对数学应用（特别是统计与分析）有兴趣", "有意向修读大学商科、社会科学、医学等", "希望深化统计及微积分基础知识"]
  },
  "curriculum_structure": {
    "organization": {
      "themes": ["基础知识", "微积分", "概率与统计"],
      "approach": ["理论讲解", "数据分析", "应用实践"]
    },
    "progression": {
      "中四": "微积分基础（极限与导数）及概率初步",
      "中五": "积分及统计推断",
      "中六": "综合应用与应考准备"
    }
  },
  "detailed_content": [
    {
      "theme": "基础知识（Foundation Knowledge）",
      "description": "为修读单元一提供代数及数学工具基础",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "基础代数与函数",
              "subtopics": [
                "多项式的运算与分解",
                "三角函数恒等式（加法公式、倍角公式）",
                "指数与对数（复习与延伸）",
                "二项式定理"
              ],
              "weighting": 10,
              "objectives": [
                "掌握单元一所需的代数基础",
                "理解三角恒等式在微积分中的应用",
                "能运用二项式定理展开式子"
              ]
            }
          ]
        }
      ]
    },
    {
      "theme": "微积分（Calculus）",
      "description": "培养学生微积分基本概念和应用能力",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "极限与导数",
              "subtopics": [
                "极限的概念",
                "导数的定义（从极限角度）",
                "基本导数法则（和差、乘积、商、链式）",
                "多项式、指数、对数及三角函数的导数",
                "隐函数微分",
                "高阶导数"
              ],
              "weighting": 20,
              "objectives": [
                "理解极限与导数的概念",
                "掌握各类函数的微分法",
                "能应用导数解决问题"
              ]
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "导数的应用",
              "subtopics": [
                "切线与法线方程",
                "函数的极大值与极小值",
                "增减性与凸凹性",
                "变化率及相关变化率",
                "最优化问题"
              ],
              "weighting": 15,
              "objectives": [
                "能利用导数分析函数行为",
                "掌握最优化方法",
                "能解决实际变化率问题"
              ]
            },
            {
              "topic": "积分",
              "subtopics": [
                "不定积分的概念",
                "基本积分公式",
                "换元积分法",
                "定积分与微积分基本定理",
                "梯形法则（数值积分）",
                "定积分的应用：面积、旋转体体积"
              ],
              "weighting": 20,
              "objectives": [
                "理解积分的概念",
                "掌握常用积分技巧",
                "能应用积分计算面积和体积"
              ]
            }
          ]
        }
      ]
    },
    {
      "theme": "概率与统计（Probability and Statistics）",
      "description": "培养学生的概率思维和统计分析能力",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "概率基础",
              "subtopics": [
                "排列与组合（复习与延伸）",
                "随机变量（离散）",
                "离散随机变量的期望值与方差",
                "二项分布（Binomial Distribution）"
              ],
              "weighting": 15,
              "objectives": [
                "理解随机变量的概念",
                "掌握期望值与方差的计算",
                "能应用二项分布解决问题"
              ]
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "概率分布",
              "subtopics": [
                "泊松分布（Poisson Distribution）",
                "正态分布（Normal Distribution）及标准化",
                "抽样分布（平均数的分布）"
              ],
              "weighting": 15,
              "objectives": [
                "理解常见离散与连续概率分布",
                "能利用正态分布解决实际问题",
                "理解抽样分布的概念"
              ]
            },
            {
              "topic": "统计推断",
              "subtopics": [
                "点估计与区间估计（均值的置信区间）",
                "假设检验（单样本z检验和t检验）",
                "相关系数",
                "线性回归分析"
              ],
              "weighting": 20,
              "objectives": [
                "掌握区间估计的方法",
                "能进行简单的假设检验",
                "能建立并解释回归模型"
              ]
            }
          ]
        }
      ]
    }
  ],
  "teaching_methodologies": {
    "approaches": [

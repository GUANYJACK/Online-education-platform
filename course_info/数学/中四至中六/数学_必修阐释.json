{
  "subject": "数学",
  "level": "中四至中六",
  "document_type": "必修阐释",
  "description": "数学必修部分课程阐释",
  "curriculum_overview": {
    "title": "数学必修部分",
    "duration": "三年",
    "note": "微积分、统计推断及概率分布均属延伸部分（单元一或单元二），不在必修范围内。必修部分的数据处理仅涵盖描述统计及初等概率。",
    "aims": [
      "培养学生的数学素养",
      "提高学生的数学思维能力",
      "培养学生的数学应用能力",
      "发展学生的创新精神和实践能力"
    ]
  },
  "curriculum_structure": {
    "organization": {
      "principles": ["螺旋式上升", "循序渐进", "知识整合", "能力培养"],
      "strands": ["数与代数", "度量、图形与空间", "数据处理"]
    },
    "progression": {
      "中四": "基础知识和技能",
      "中五": "概念深化和应用",
      "中六": "综合提升和备考"
    }
  },
  "detailed_content": [
    {
      "strand": "数与代数",
      "description": "培养学生的数感和代数思维",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "二次方程式",
              "subtopics": ["因式分解法", "配方法", "求根公式", "判别式", "根与系数的关系（韦达定理）"],
              "weighting": 8
            },
            {
              "topic": "函数及其图象",
              "subtopics": ["二次函数", "线性函数", "绝对值函数", "函数的基本特征（定义域、值域、对称性）"],
              "weighting": 8
            },
            {
              "topic": "指数函数及对数函数",
              "subtopics": ["指数函数的性质和图象", "对数函数的性质和图象", "指数方程", "对数方程", "指数与对数的相互转换"],
              "weighting": 6
            },
            {
              "topic": "多项式",
              "subtopics": ["多项式除法", "余数定理", "因子定理", "高次多项式方程"],
              "weighting": 6
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "有理函数",
              "subtopics": ["有理函数化简", "部分分式"],
              "weighting": 4
            },
            {
              "topic": "数列",
              "subtopics": ["等差数列（通项、求和）", "等比数列（通项、求和）", "数列的应用"],
              "weighting": 6
            },
            {
              "topic": "不等式",
              "subtopics": ["绝对值不等式", "二次不等式", "不等式的应用"],
              "weighting": 5
            },
            {
              "topic": "线性规划",
              "subtopics": ["线性约束条件", "可行域", "目标函数", "图解法", "实际应用"],
              "weighting": 5
            }
          ]
        }
      ]
    },
    {
      "strand": "度量、图形与空间",
      "description": "培养学生的空间想象和几何思维",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "圆的基本性质",
              "subtopics": ["圆心角与圆周角的关系", "同弧所对圆周角", "圆内接四边形性质", "切线的性质", "切线与弦角"],
              "weighting": 8
            },
            {
              "topic": "三角比",
              "subtopics": ["锐角及钝角的三角比定义", "三角比的基本关系", "直角三角形的解法", "仰角与俯角"],
              "weighting": 7
            },
            {
              "topic": "直线方程",
              "subtopics": ["直线斜率", "直线方程的各种形式", "两直线的相交与平行", "点与直线的距离"],
              "weighting": 6
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "更多三角学",
              "subtopics": ["正弦定理", "余弦定理", "三角形面积公式", "平面三角形应用题", "立体三角学（三维空间中的角度与距离）"],
              "weighting": 8
            },
            {
              "topic": "圆的方程",
              "subtopics": ["圆的标准方程", "圆的一般方程", "点与圆的关系", "切线方程", "轨迹问题"],
              "weighting": 7
            },
            {
              "topic": "更多关于坐标几何",
              "subtopics": ["简单轨迹的坐标处理", "直线与圆的综合问题"],
              "weighting": 4
            },
            {
              "topic": "几何变换",
              "subtopics": ["平移", "反射", "旋转", "放大/缩小"],
              "weighting": 4
            },
            {
              "topic": "立体图形",
              "subtopics": ["棱柱和棱锥的表面积与体积", "圆柱、圆锥、球的表面积与体积", "组合立体图形"],
              "weighting": 4
            }
          ]
        }
      ]
    },
    {
      "strand": "数据处理",
      "description": "培养学生的数据分析能力及初等概率思维（不含统计推断或概率分布）",
      "content_by_level": [
        {
          "level": "中五",
          "topics": [
            {
              "topic": "排列与组合",
              "subtopics": ["加法原理与乘法原理", "排列数（P）", "组合数（C）", "排列与组合的应用"],
              "weighting": 6
            },
            {
              "topic": "概率",
              "subtopics": ["概率的古典定义", "简单事件的概率", "互斥事件", "独立事件", "条件概率（基础）"],
              "weighting": 6
            },
            {
              "topic": "统计（描述统计）",
              "subtopics": [
                "频数分布与频率分布",
                "累积频率曲线（Ogive）",
                "集中趋势：平均数、中位数、众数",
                "离散程度：范围、四分位差、标准差、方差",
                "茎叶图、箱线图（Box-and-Whisker Plot）"
              ],
              "weighting": 6
            }
          ]
        }
      ]
    }
  ],
  "teaching_methodologies": {
    "approaches": [
      "探究式学习",
      "合作学习",
      "问题解决教学",
      "数学建模"
    ],
    "strategies": [
      "概念建构",
      "技能训练",
      "应用拓展",
      "思维训练"
    ],
    "classroom_practices": [
      "小组讨论",
      "数学实验",
      "项目学习",
      "数学游戏"
    ]
  },
  "assessment_strategies": {
    "school_based_assessment": {
      "weighting": 20,
      "description": "校本评估（SBA）——探究或统计项目（Investigation or Statistical Project）",
      "components": [
        {
          "component": "探究或统计项目",
          "weighting": 20,
          "description": "学生在中四至中六期间完成一份探究性或统计性项目报告"
        }
      ]
    },
    "public_exam": {
      "weighting": 80,
      "components": [
        {
          "component": "卷一（Paper 1）",
          "description": "传统笔试题，甲部（短题）及乙部（长题），共105分，考试时间2小时30分钟"
        },
        {
          "component": "卷二（Paper 2）",
          "description": "多项选择题，共45题，考试时间1小时15分钟"
        }
      ]
    }
  },
  "learning_outcomes": {
    "knowledge_outcomes": [
      "掌握数学基础概念和原理",
      "理解数学概念之间的联系",
      "了解数学的应用价值"
    ],
    "skill_outcomes": [
      "发展数学思维能力",
      "提高问题解决能力",
      "培养数学建模能力"
    ],
    "attitude_outcomes": [
      "培养数学学习兴趣",
      "发展积极的数学态度",
      "培养科学精神"
    ]
  },
  "resource_requirements": {
    "textbooks": [
      "数学必修部分教科书",
      "练习册",
      "参考书"
    ],
    "equipment": [
      "计算器",
      "几何工具",
      "计算机软件"
    ],
    "technology": [
      "图形计算器",
      "数学软件",
      "在线学习平台"
    ]
  }
}

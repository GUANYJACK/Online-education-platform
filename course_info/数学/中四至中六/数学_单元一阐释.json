  },
  "learning_outcomes": {
    "knowledge": [
      "掌握微积分（导数与积分）的基本概念与技巧",
      "理解常用概率分布（二项、泊松、正态）",
      "了解统计推断的基本方法（估计、假设检验、回归）"
    ],
    "skills": [
      "发展数学分析能力",
      "提高数据分析和统计思维能力",
      "培养数学建模能力"
    ],
    "applications": [
      "能够应用微积分解决变化率和最优化问题",
      "能够进行数据分析和统计推断",
      "能够建立简单的线性回归模型"
    ]
  },

    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "  {\r\n    \"name\": \"John Doe\",\r\n    \"email\": \"john@example.com\",\r\n    \"phone\": \"123456789\",\r\n    \"password\": \"password123\",\r\n    \"role\": \"STUDENT\" // Available Roles: STUDENT, PARENT, TEACHER, SCHOOL_ADMIN\r\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/auth/register",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2. Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json;",
                  "let token;",
                  "",
                  "pm.test('Response body is valid JSON', function () {",
                  "    pm.expect(function () {",
                  "        json = pm.response.json();",
                  "    }).to.not.throw();",
                  "});",
                  "",
                  "if (json) {",
                  "    token = json.token || json.access_token || json.authToken || json.jwt || (json.data && (json.data.token || json.data.access_token));",
                  "}",
                  "",
                  "pm.test('Token exists in response and is saved', function () {",
                  "    pm.expect(token, 'Expected a token field in the response body').to.be.a('string').and.not.empty;",
                  "",
                  "    if (token) {",
                  "        pm.collectionVariables.set('token', token);",
                  "        pm.expect(pm.collectionVariables.get('token')).to.eql(token);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@family.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BaseURL}}/auth/login",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login the user if input with correct username and password. Returns with a bearer token for later use. For convenience, the token already retrieved by script already can would be passed to later API calls.\n\nYou may test with different role for some already exists account:\n\n1. Student: [student@school.com](https://mailto:student@school.com)\n    \n2. Parent: [parent@family.com](https://mailto:parent@family.com)\n    \n3. Teacher: [teacher@school.com](https://mailto:teacher@school.com)\n    \n4. School Admin: [admin@school.com](https://mailto:admin@school.com)\n    \n\nWhere the password for all account are: **password123**"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "1. Get User id by Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData;",
                  "try {",
                  "    jsonData = pm.response.json();",
                  "} catch (e) {",
                  "    throw new Error('Response body is not valid JSON');",
                  "}",
                  "",
                  "if (!jsonData || typeof jsonData.id === 'undefined') {",
                  "    throw new Error('Response JSON does not contain an id field');",
                  "}",
                  "",
                  "pm.collectionVariables.set('id', String(jsonData.id));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BaseURL}}/users/uuid-by-email?email=student@school.com",
              "host": [
                "{{BaseURL}}"
              ],
              "path": [
                "users",
                "uuid-by-email"
              ],
              "query": [
                {
                  "key": "email",
                  "value": "student@school.com"
                }
              ]
            }
          },
          "response": []
        },

{
  "subject": "数学",
  "level": "中四至中六",
  "document_type": "延伸单元阐释",
  "description": "数学延伸部分（单元二）课程阐释",
  "unit_overview": {
    "title": "数学延伸部分（单元二：代数与微积分）",
    "focus": "代数与微积分",
    "prerequisites": ["数学必修部分"],
    "target_students": ["对纯数学及理工科有浓厚兴趣", "有意向修读大学理工科（工程、物理等）", "希望深化代数与微积分知识"]
  },
  "curriculum_structure": {
    "organization": {
      "themes": ["基础知识", "向量与矩阵", "微积分"],
      "approach": ["理论讲解", "问题解决", "应用拓展"]
    },
    "progression": {
      "中四": "基础知识（代数运算、三角恒等式、数学归纳法）及向量",
      "中五": "矩阵与方程组及微积分",
      "中六": "微积分进阶与综合应用"
    }
  },
  "detailed_content": [
    {
      "theme": "基础知识（Foundation Knowledge）",
      "description": "为修读单元二提供代数及推理基础",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "代数基础",
              "subtopics": [
                "多项式运算与分解",
                "三角恒等式（倍角公式、积化和差）",
                "数学归纳法（Mathematical Induction）",
                "反证法（Proof by Contradiction）"
              ],
              "weighting": 10,
              "objectives": [
                "掌握单元二所需代数工具",
                "理解数学证明方法",
                "能运用数学归纳法进行证明"
              ]
            }
          ]
        }
      ]
    },
    {
      "theme": "向量与矩阵（Vectors and Matrices）",
      "description": "培养学生的空间思维与线性代数应用能力",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "二维及三维向量",
              "subtopics": [
                "向量的概念与表示",
                "向量的加减与数乘",
                "向量的内积（点积）",
                "向量与直线（参数方程）",
                "向量在几何证明中的应用"
              ],
              "weighting": 15,
              "objectives": [
                "理解向量的概念和运算",
                "掌握内积的计算与应用",
                "能用向量解决几何问题"
              ]
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "向量进阶",
              "subtopics": [
                "三维空间中的向量",
                "向量的外积（叉积）",
                "直线与平面的向量方程",
                "三维几何应用"
              ],
              "weighting": 15,
              "objectives": [
                "掌握三维向量运算",
                "理解外积及其应用",
                "能解决三维空间几何问题"
              ]
            },
            {
              "topic": "矩阵与线性方程组",
              "subtopics": [
                "矩阵的运算（加减、数乘、乘法）",
                "行列式（2×2及3×3）",
                "逆矩阵",
                "用矩阵解线性方程组（克莱默法则、行化简）"
              ],
              "weighting": 15,
              "objectives": [
                "掌握矩阵运算",
                "理解行列式的计算与应用",
                "能利用矩阵解线性方程组"
              ]
            }
          ]
        }
      ]
    },
    {
      "theme": "微积分（Calculus）",
      "description": "培养学生的数学分析能力",
      "content_by_level": [
        {
          "level": "中四",
          "topics": [
            {
              "topic": "极限与微分",
              "subtopics": [
                "极限的概念与运算",
                "导数的定义",
                "基本导数法则（和差积商、链式法则）",
                "多项式、指数、对数及三角函数的导数",
                "隐函数微分",
                "参数方程微分"
              ],
              "weighting": 15,
              "objectives": [
                "理解极限与导数概念",
                "掌握各类函数的微分法",
                "能对隐函数和参数方程求导"
              ]
            }
          ]
        },
        {
          "level": "中五",
          "topics": [
            {
              "topic": "微分的应用与进阶",
              "subtopics": [
                "高阶导数",
                "洛必达法则（L'Hôpital's Rule）",
                "函数的极大极小值与凸凹性",
                "最优化问题",
                "变化率与相关变化率"
              ],
              "weighting": 10,
              "objectives": [
                "掌握高阶导数",
                "能应用洛必达法则",
                "能解决最优化及变化率问题"
              ]
            },
            {
              "topic": "积分",
              "subtopics": [
                "不定积分与基本公式",
                "换元积分法",
                "分部积分法",
                "部分分式积分",
                "定积分与微积分基本定理",
                "积分的应用（面积、旋转体体积、弧长）"
              ],
              "weighting": 20,
              "objectives": [
                "掌握多种积分技巧",
                "理解定积分的几何意义",
                "能计算面积、体积及弧长"
              ]
            }
          ]
        },
        {
          "level": "中六",
          "topics": [
            {
              "topic": "微积分综合应用",
              "subtopics": [
                "一阶微分方程（可分离变量型、线性型）",
                "级数与收敛性（基础）",
                "综合专题练习"
              ],
              "weighting": 15,
              "objectives": [
                "能求解简单微分方程",
                "理解级数的基本概念",
                "能综合运用微积分知识"
              ]
            }
          ]
        }
      ]
    }
  ],
